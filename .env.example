# Puerto en el que se ejecutará la aplicación
PORT=3000

# Para generar una imagen en docker con la base de datos de postgres (solo tener en desarrollo)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# Para firmas de las imagenes
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=

# Clave secreta para firmar los JWT
JWT_SECRET=

# Entorno de ejecución: production, development o test
NODE_ENV=production

# URL de conexión a la base de datos (producción o desarrollo): colocarlo ente comillas dobles 
DATABASE_URL=
